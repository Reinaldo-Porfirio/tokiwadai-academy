# Database - Para desenvolvimento local, use SQLite
DATABASE_URL="file:./dev.db"

# JWT Secret - Use qualquer string aleatória
JWT_SECRET="tokiwadai-academy-development-secret-key-2026"

# OAuth (Manus) - Configuração obrigatória
VITE_APP_ID="tokiwadai-academy-dev"
